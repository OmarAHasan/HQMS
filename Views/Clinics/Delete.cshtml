@model HospitalQueueMS.Models.Clinic
@{
    Layout = "_Layout";
    ViewData["Title"] = "Delete Clinic";
}


<h2>Delete Clinic</h2>

<div class="alert alert-warning">
    <strong>Are you sure you want to delete this clinic?</strong>
</div>

<dl class="row">
    <dt class="col-sm-3">Clinic Name</dt>
    <dd class="col-sm-9">@Model.ClinicName</dd>

    <dt class="col-sm-3">Department</dt>
    <dd class="col-sm-9">@Model.Department?.DepartmentName</dd>
</dl>

<form asp-action="DeleteConfirmed" method="post">
    <input type="hidden" asp-for="ClinicId" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>
