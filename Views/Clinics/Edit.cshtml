@model HospitalQueueMS.Models.Clinic
@{
    Layout = "_Layout";
    ViewData["Title"] = "Edit Clinic";
}
<h2>Edit Clinic</h2>

<form method="post">
    <input type="hidden" asp-for="ClinicId" />

    <div class="form-group">
        <label>Clinic Name:</label>
        <input asp-for="ClinicName" class="form-control" />
    </div>

    <div class="form-group">
        <label>Department:</label>
        <select asp-for="DepartmentId" asp-items="ViewBag.Departments" class="form-control"></select>
    </div>

    <button type="submit" class="btn btn-success">Save</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>
