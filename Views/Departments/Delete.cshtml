@model HospitalQueueMS.Models.Department

@{
    Layout = "_Layout";
    ViewData["Title"] = "Delete Department";
}

<div class="container mt-4">
    <h2 class="text-danger mb-3">Delete Department</h2>

    <div class="alert alert-warning">
        <strong>Are you sure you want to delete this department?</strong>
    </div>

    <dl class="row">
        <dt class="col-sm-3">Department Name</dt>
        <dd class="col-sm-9">@Model.DepartmentName</dd>
    </dl>

    <form asp-action="DeleteConfirmed" method="post">
        <input type="hidden" asp-for="DepartmentId" />
        <button type="submit" class="btn btn-danger">Delete</button>
        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
    </form>
</div>
