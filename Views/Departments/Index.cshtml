@model IEnumerable<HospitalQueueMS.Models.Department>

@{
    Layout = "_Layout";
    ViewData["Title"] = "Departments";
}

<div class="container mt-4">
    <h2 class="text-primary mb-3">Departments</h2>
    <a asp-action="Create" class="btn btn-success mb-3">Add New Department</a>

    <table class="table table-bordered table-striped">
        <thead class="table-dark">
            <tr>
                <th>Department Name</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var dept in Model)
            {
                <tr>
                    <td>@dept.DepartmentName</td>
                    <td>
                        <a asp-action="Edit" asp-route-id="@dept.DepartmentId" class="btn btn-warning btn-sm">Edit</a>
                        <a asp-action="Delete" asp-route-id="@dept.DepartmentId" class="btn btn-danger btn-sm">Delete</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
