@{
    Layout = "_Layout";
    ViewData["Title"] = "Doctor Dashboard";
}

<h2 class="mb-4 text-primary">Doctor Dashboard</h2>

<div class="row">
    <div class="col-md-9">
        <div class="list-group">
        <a class="list-group-item list-group-item-action btn btn-info" asp-controller="Tokens" asp-action="Index">Manage Tokens / Queue</a>
        </div>
    </div>

    <!-- sidebar -->
    <div class="col-md-3">
        @await Component.InvokeAsync("Stats")
    </div>
</div>


