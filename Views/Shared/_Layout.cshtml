<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - HQMS</title>
    <link rel="stylesheet" href="~/css/site.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <div class="container-fluid">
            <a class="navbar-brand" asp-controller="Home" asp-action="Index">HQMS</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto">
                    @if (User.Identity.IsAuthenticated)
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Tokens" asp-action="WaitingRoom">Waiting</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Tokens" asp-action="CompletedTokens">Completed</a>
                        </li>
                        <form asp-controller="Users" asp-action="Logout" method="post" class="d-inline">
                            <button type="submit" class="nav-link btn btn-link">Logout</button>
                        </form>

                    }
                </ul>
            </div>
        </div>
    </nav>

    <main role="main" class="pb-3">
        <div class="container" style="max-width: 900px;">
            @RenderBody()
        </div>
    </main>
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

    <!-- Bootstrap -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    @RenderSection("Scripts", required: false)

    <footer class="footer">
        <p>© Developed by OmarHasan @DateTime.Now.Year</p>
    </footer>

</body>
</html>
