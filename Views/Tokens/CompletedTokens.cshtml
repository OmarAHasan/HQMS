@model IEnumerable<HospitalQueueMS.Models.Token>
@{
    Layout = "_Layout";
    ViewData["Title"] = "Create Token";
}
<h2>Completed Patients</h2>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Patient Number</th>
            <th>Mobile Number</th>
            <th>Department</th>
            <th>Clinic</th>
            <th>Priority</th>
            <th>Completed At</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var token in Model)
        {
            <tr>
                <td>@token.TokenCode</td>
                <td>@token.MobileNumber</td>
                <td>@token.Clinic.Department.DepartmentName</td>
                <td>@token.Clinic.ClinicName</td>
                <td>@token.Priority</td>
                <td>@token.CompletedAt?.ToString("dd/MM/yyyy HH:mm")</td>
            </tr>
        }
    </tbody>
</table>

@if (User.IsInRole("Admin"))
{
    <form asp-action="DeleteCompleted" method="post">
        <button type="submit" class="btn btn-danger">Delete All</button>
    </form>
}
