@{
    ViewData["Title"] = "Create Token";
}

<h2>Create Token</h2>

<form asp-action="CreateToken" method="post">
    <div>
        <label>Select Clinic:</label>
        <select name="clinicId">
            @foreach (var dept in ViewBag.Departments)
            {
                foreach (var clinic in dept.Clinics)
                {
                    <option value="@clinic.ClinicId">@dept.DepartmentName - @clinic.ClinicName</option>
                }
            }
        </select>
    </div>
    <button type="submit">Create Token</button>
</form>

@if (ViewBag.TokenNumber != null)
{
    <h2>Token Created</h2>
    <p>Your token number is: <strong>@ViewBag.TokenNumber</strong></p>
}
