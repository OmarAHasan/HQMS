@model HospitalQueueMS.Models.Token

@{
    ViewData["Title"] = "Delete Token";
}

<h2>Delete Token</h2>

<h3>Are you sure you want to delete this token?</h3>
<div>
    <h4>Token</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">Token Number</dt>
        <dd class="col-sm-10">@Model.TokenNumber</dd>

        <dt class="col-sm-2">Patient</dt>
        <dd class="col-sm-10">@Model.Patient?.FullName</dd>

        <dt class="col-sm-2">Clinic</dt>
        <dd class="col-sm-10">@Model.Clinic?.ClinicName</dd>

        <dt class="col-sm-2">Status</dt>
        <dd class="col-sm-10">@Model.Status</dd>

        <dt class="col-sm-2">Priority</dt>
        <dd class="col-sm-10">@Model.Priority</dd>
    </dl>
</div>

<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="TokenId" />
    <button type="submit" class="btn btn-danger">Delete</button> |
    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
</form>
