@model HospitalQueueMS.Models.Token

@{
    ViewData["Title"] = "Edit Token";
}

<h2>Edit Token</h2>

<form asp-action="Edit" method="post">
    <input type="hidden" asp-for="TokenId" />

    <div class="form-group">
        <label asp-for="PatientId" class="control-label"></label>
        <select asp-for="PatientId" asp-items="ViewBag.PatientId" class="form-control"></select>
        <span asp-validation-for="PatientId" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="ClinicId" class="control-label"></label>
        <select asp-for="ClinicId" asp-items="ViewBag.ClinicId" class="form-control"></select>
        <span asp-validation-for="ClinicId" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="Priority" class="control-label"></label>
        <select asp-for="Priority" asp-items="ViewBag.Priority" class="form-control"></select>
        <span asp-validation-for="Priority" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="Status" class="control-label"></label>
        <select asp-for="Status" asp-items="ViewBag.Status" class="form-control"></select>
        <span asp-validation-for="Status" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary">Update</button> |
    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
</form>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
