@model HospitalQueueMS.Models.Token

@{
    Layout = "_Layout";
    ViewData["Title"] = "Edit Token";
}

<h2>Edit Token</h2>

<form asp-action="Edit" method="post">
    <input type="hidden" asp-for="TokenId" />

    <div class="form-group mb-3">
        <label>Department</label>
        <select asp-for="DepartmentId" asp-items="ViewBag.Departments" class="form-control"></select>
    </div>

    <div class="form-group mb-3">
        <label>Clinic</label>
        <select asp-for="ClinicId" asp-items="ViewBag.Clinics" class="form-control"></select>
    </div>

    <div class="form-group mb-3">
        <label>Priority</label>
        <select asp-for="Priority" asp-items="ViewBag.Priorities" class="form-control"></select>
    </div>


    <button type="submit" class="btn btn-primary">Update</button> |
    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
</form>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
