@model IEnumerable<HospitalQueueMS.Models.Token>
@{
    Layout = null;
}

<table class="table table-striped">
    <thead>
        <tr>
            <th>Token Number</th>
            <th>Department</th>
            <th>Clinic</th>
            <th>Status</th>
            <th>Priority</th>
            <th>Created At</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var token in Model)
        {
            <tr id="row-@token.TokenId">
                <td>@token.TokenCode</td>
                <td>@token.Clinic?.Department?.DepartmentName</td>
                <td>@token.Clinic?.ClinicName</td>
                <td>@token.Status</td>
                <td>@token.Priority</td>
                <td>@token.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                <td>
                    @if (User.IsInRole("Doctor") || User.IsInRole("Admin"))
                    {
                    if (token.Status == TokenStatus.Waiting)
                    {
                    <a href="javascript:void(0);"
                       onclick="callNext(@token.TokenId, '@token.TokenCode', '@token.Clinic?.ClinicName')"
                       class="btn btn-sm btn-primary">Call Next</a>
                    }
                    else if (token.Status == TokenStatus.InProgress)
                    {
                    <a href="javascript:void(0);" onclick="completeToken(@token.TokenId)" class="btn btn-sm btn-success">Complete</a>
                    }
                    }
                    <a asp-action="Edit" asp-route-id="@token.TokenId" class="btn btn-warning btn-sm">Edit</a>
                    <a asp-action="Delete" asp-route-id="@token.TokenId" class="btn btn-danger btn-sm">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>
