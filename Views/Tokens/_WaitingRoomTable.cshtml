@model IEnumerable<HospitalQueueMS.Models.Token>
@{
    Layout = null;
}

<table class="table table-striped">
    <thead>
        <tr>
            <th>Token Number</th>
            <th>Department</th>
            <th>Clinic</th>
            <th>Status</th>
            <th>Priority</th>
            <th>Created At</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var token in Model)
        {
            <tr id="row-@token.TokenId">
                <td>@token.TokenCode</td>
                <td>@token.Clinic?.Department?.DepartmentName</td>
                <td>@token.Clinic?.ClinicName</td>
                <td>@token.Status</td>
                <td>@token.Priority</td>
                <td>@token.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>
            </tr>
        }
    </tbody>
</table>
